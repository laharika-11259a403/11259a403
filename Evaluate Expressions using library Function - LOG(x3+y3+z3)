#include <stdio.h>
#include <math.h> 
int main() {
  double x, y, z, result; 
  printf("Enter value of x: ");
  scanf("%lf", &x);
  printf("Enter value of y: "); 
  scanf("%lf", &y); 
  printf("Enter value of z: ");
  scanf("%lf", &z); 
  result = log(pow(x, 3) + pow(y, 3) + pow(z, 3));
  printf("The value of log(x^3 + y^3 + z^3) = %.4lf\n", result); 
  return 0; 
}   
