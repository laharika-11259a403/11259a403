#include <stdio.h> 
#include <string.h>
#include <stdlib.h> 
int main() { 
   char str1[100], str2[100], result[100];
   int choice, i, len; while (1) { 
   printf("\n--- String Operations Menu ---\n"); 
   printf("1. String Copy\n"); 
   printf("2. String Reverse\n");
   printf("3. String Concatenate\n");  
   printf("4. Exit\n");
   printf("Enter your choice: ");  
   scanf("%d", &choice); getchar();
  // to clear newline from buffer 
  switch (choice) { 
case 1: 
  printf("Enter a string: ");
  gets(str1); 
  strcpy(result, str1);
  printf("Copied string: %s\n", result); 
  break;
case 2:
  printf("Enter a string: "); 
  gets(str1); 
  len = strlen(str1);
  for (i = 0; i < len; i++) { 
  result[i] = str1[len - i - 1];
 }
  result[len] = '\0';
}
  result[len] = '\0';
  printf("Reversed string: %s\n", result); 
  break;
case 3:
   printf("Enter first string: "); 
   gets(str1); 
   printf("Enter second string: "); 
   gets(str2); 
   strcpy(result, str1); 
   strcat(result, str2);
   printf("Concatenated string: %s\n", result); 
   break;
case 4: 
   printf("Exiting program...\n");
   exit(0);
   default:
   printf("Invalid choice! Please try again.\n");    
}
 }
return 0;
}
