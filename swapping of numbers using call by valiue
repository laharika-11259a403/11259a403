#include <stdio.h>
void swapValue(int x, int y) { 
  int temp;
  temp = x;
  x = y; 
  y = temp;
  printf("Inside function (Call by Value): a = %d, b = %d\n", x, y);
}
  int main() {
  int a, b; printf("Enter two numbers: "); 
  scanf("%d %d", &a, &b); 
  swapValue(a, b); 
  printf("After function call (Main): a = %d, b = %d\n", a, b); 
  return 0;
  }   
