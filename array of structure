#include <stdio.h> 
struct Student {
  char name[20]; 
  int roll; 
  float marks; };
  int main() {
  struct Student s[100]; 
// Array of structures 
  int n, i; 
  printf("Enter number of students: ");
  scanf("%d", &n); 
// Input student details 
  for(i = 0; i < n; i++) { 
  printf("\nEnter details for student %d:\n", i+1);
  printf("Name: ");
  scanf("%s", s[i].name);
  printf("Roll Number: ");
  scanf("%d", &s[i].roll); 
  printf("Marks: "); 
  scanf("%f", &s[i].marks);
 }
// Display student details
  printf("\nStudent Details:\n");
  printf(" \n");
  printf("Name\tRoll\tMarks\n"); 
  printf(" \n"); 
  for(i = 0; i < n; i++) { 
  printf("%s\t%d\t%.2f\n", s[i].name, s[i].roll, s[i].marks); 
}
 return 0;
} 
